# Read-only lane (SLC9000 primary lab device)
slc_read_host: "192.0.2.1"
slc_read_username: "sysadmin"
slc_read_password: "changeme"
slc_read_hostname: "slc9000"

# Write lane (SLC9000 secondary lab device)
slc_write_host: "192.0.2.2"
slc_write_username: "sysadmin"
slc_write_password: "changeme"
slc_write_hostname: "slc9000-write"

# Percepxion, primary project (read-only lane)
percepxion_read_host: "api.gopercepxion.ai"
percepxion_read_username: "user@example.com"
percepxion_read_password: "changeme"

# Percepxion, write project (write lane)
percepxion_host: "api.gopercepxion.ai"
